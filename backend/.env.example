# Configuracoes de Banco de dados
PORT=3001
DB_HOST=localhost
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=nome_do_seu_banco
JWT_SECRET=sua_chave_secreta_jwt

# Configuracoes de Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_gmail
EMAIL_FROM=Nome do App <seu_email@gmail.com>
APP_URL=http://localhost:3001

# Frontend autorizado no CORS
# FRONTEND_URL aceita 1 URL
FRONTEND_URL=http://localhost:3000
# FRONTEND_URLS aceita varias URLs separadas por virgula
# FRONTEND_URLS=https://seu-frontend.vercel.app,https://outro-dominio.com

# Integracoes opcionais do IAn
# Necessario para enriquecer sugestoes de ativos com cotacoes do mercado brasileiro
BRAPI_TOKEN=
